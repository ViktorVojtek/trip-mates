PORT=5000
NODE_ENV=development
JWT_SECRET=your-super-secret-jwt-key-change-in-production
DATABASE_URL="postgresql://user:password@localhost:5432/tripmates"
# Allowed origin for Socket.IO (real-time chat). Defaults to * if unset.
CLIENT_ORIGIN=http://localhost:5173

# Email notifications (optional — omit SMTP_HOST to disable email entirely)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Trip Mates <no-reply@tripmates.app>"

# Google OAuth (optional — omit to disable Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
